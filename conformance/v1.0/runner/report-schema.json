{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.agentthreatrule.org/conformance/v1.0/report.json",
  "title": "ATR Conformance Report",
  "type": "object",
  "required": ["suite_version", "spec_version", "engine", "rules", "level", "generated_at", "totals", "results"],
  "properties": {
    "suite_version": { "type": "string", "const": "v1.0.0" },
    "spec_version": { "type": "string", "const": "1.0.0" },
    "engine": { "type": "string" },
    "rules": { "type": "string" },
    "level": { "type": "string", "enum": ["L1", "L2", "L3"] },
    "generated_at": { "type": "string", "format": "date-time" },
    "totals": {
      "type": "object",
      "required": ["total", "passed", "failed"],
      "properties": {
        "total": { "type": "integer", "minimum": 0 },
        "passed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      }
    },
    "results": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["fixture", "category", "expected", "observed", "passed", "runtime_ms"],
        "properties": {
          "fixture": { "type": "string" },
          "category": { "type": "string", "enum": ["tp", "tn", "edge"] },
          "rule_id": { "type": "string" },
          "expected": { "type": "string" },
          "observed": { "type": "string" },
          "passed": { "type": "boolean" },
          "runtime_ms": { "type": "integer", "minimum": 0 },
          "failure_reason": { "type": "string" }
        }
      }
    }
  }
}
